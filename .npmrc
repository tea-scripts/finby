auto-install-peers=true
strict-peer-dependencies=false
# React Native / Expo (apps/mobile) assume a flat node_modules and import
# "phantom" deps they don't declare (e.g. @expo/metro-runtime → whatwg-fetch).
# pnpm's default isolated store + Metro's disableHierarchicalLookup break those.
# Hoisted linker is Expo's documented fix for RN in a pnpm monorepo.
node-linker=hoisted

# ─────────────────────────────────────────────
# Finby — Environment Variables
# Copy to `.env` and fill in. Never commit `.env`.
# Values marked (Phase N) are not consumed until that phase;
# they may be left blank in earlier phases.
# ─────────────────────────────────────────────

# ─── App ───
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# ─── Web (Next.js — must be NEXT_PUBLIC_ to reach the browser) ───
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
# PostHog product analytics. Leave the key blank to disable analytics entirely.
NEXT_PUBLIC_POSTHOG_KEY=
# Ingestion host. Defaults to the first-party reverse proxy `/ingest` (see
# apps/web/next.config.mjs rewrites), which evades ad blockers. Only override to
# bypass the proxy (e.g. https://us.i.posthog.com) or for an EU project.
# NEXT_PUBLIC_POSTHOG_HOST=/ingest

# ─── Admin dashboard (apps/admin — separate Next.js app on :3002) ───
# The admin API client prepends the `/api/v1` prefix itself, so set this to the
# bare origin (NO `/api/v1` suffix — unlike the web value above). Defaults to
# http://localhost:3001 if unset. Configure in apps/admin/.env.local, not here.
# NEXT_PUBLIC_API_URL=http://localhost:3001
# API-side: admin app origin, added to the CORS allowlist so the browser can call admin endpoints.
ADMIN_WEB_URL=http://localhost:3002
# API-side admin auth (super-admin dashboard). Leave ADMIN_EMAILS blank to disable admin auth.
# Comma-separated allowlist of admin emails (must be existing Finby user accounts).
ADMIN_EMAILS=
# API-side PostHog query access — powers the admin dashboard's behavioural funnels.
# Optional: the funnel endpoint returns { configured:false } until KEY + PROJECT_ID are set.
# POSTHOG_API_HOST is the *app* host (us.posthog.com), NOT the ingestion host (us.i.posthog.com).
POSTHOG_API_KEY=        # personal API key (phx_…), scope query:read
POSTHOG_PROJECT_ID=     # numeric project id
# POSTHOG_API_HOST=https://us.posthog.com
# Required when ADMIN_EMAILS is set. Generate a strong random value, e.g. `openssl rand -hex 32`.
ADMIN_JWT_SECRET=
ADMIN_JWT_TTL=8h
ADMIN_TOTP_ISSUER=Finby Admin
# Optional: Sentry dashboard URL shown as a link-out in the ops panel.
ADMIN_SENTRY_URL=

# ─── Database (Postgres — docker-compose maps to :5434) ───
DATABASE_URL=postgresql://finby:finby@localhost:5434/finby?schema=public

# ─── Redis (docker-compose maps to :6380) ───
REDIS_URL=redis://localhost:6380

# ─── Rate limiting (global fallback — auth routes have stricter per-route limits) ───
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# ─── Auth / JWT ───
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=12

# ─── LLM / Anthropic (Phase 2) ───
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── FX rates (Phase 2) — tried in priority order ───
EXCHANGE_RATE_API_URL=https://open.er-api.com
FRANKFURTER_API_URL=https://api.frankfurter.dev/v1

# ─── Market data / Alpha Vantage (Phase 4) ───
ALPHA_VANTAGE_API_KEY=
ALPHA_VANTAGE_API_URL=https://www.alphavantage.co

# ─── Billing (Phase 5) ───
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

# ─── Lemon Squeezy (Merchant of Record — global payments) ───
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_VARIANT_PRO=        # subscription variant id per paid tier
LEMONSQUEEZY_VARIANT_PREMIUM=
LEMONSQUEEZY_VARIANT_FAMILY=

# ─── Web Push / VAPID (Phase 5) ───
# Generate with: node -e "console.log(require('web-push').generateVAPIDKeys())"
# Push delivery no-ops until both keys are set.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@finby.app

# ─── Email / Resend ───
# Unset ⇒ emails are skipped (logged). Verify the finby.app domain in Resend before go-live.
RESEND_API_KEY=
EMAIL_FROM=Finby <noreply@finby.app>
# Inbox that receives user review notifications (defaults to support@finby.app).
FEEDBACK_NOTIFY_TO=support@finby.app

# ─── Chat memory token budgets (Phase 2) ───
# Tunable per tier; schema defaults shown. Raise for more context, lower to cut LLM cost.
FREE_ACTIVE_WINDOW_TOKEN_BUDGET=4000
PRO_COMPRESSION_THRESHOLD=8000
PREMIUM_COMPRESSION_THRESHOLD=12000

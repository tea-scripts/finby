# ─────────────────────────────────────────────
# Finby — Environment Variables
# Copy to `.env` and fill in. Never commit `.env`.
# Values marked (Phase N) are not consumed until that phase;
# they may be left blank in earlier phases.
# ─────────────────────────────────────────────

# ─── App ───
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# ─── Web (Next.js — must be NEXT_PUBLIC_ to reach the browser) ───
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# ─── Database (Postgres — docker-compose maps to :5434) ───
DATABASE_URL=postgresql://finby:finby@localhost:5434/finby?schema=public

# ─── Redis (docker-compose maps to :6380) ───
REDIS_URL=redis://localhost:6380

# ─── Auth / JWT ───
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=12

# ─── LLM / Anthropic (Phase 2) ───
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── FX rates / Frankfurter (Phase 2) ───
FRANKFURTER_API_URL=https://api.frankfurter.app

# ─── Market data / Alpha Vantage (Phase 4) ───
ALPHA_VANTAGE_API_KEY=
ALPHA_VANTAGE_API_URL=https://www.alphavantage.co

# ─── Billing (Phase 5) ───
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

# ─── Lemon Squeezy (Merchant of Record — global payments) ───
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_VARIANT_PRO=        # subscription variant id per paid tier
LEMONSQUEEZY_VARIANT_PREMIUM=
LEMONSQUEEZY_VARIANT_FAMILY=

# ─── Web Push / VAPID (Phase 5) ───
# Generate with: node -e "console.log(require('web-push').generateVAPIDKeys())"
# Push delivery no-ops until both keys are set.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@finby.app
